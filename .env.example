# Copiar a ".env" (gitignored) y ajustar valores.
# docker-compose lee ".env" automáticamente para las variables ${...} de docker-compose.yml.
# Para levantar el backend en perfil "dev" (mvn spring-boot:run), exportar estas
# mismas variables en la shell, o usar un plugin como direnv / spring-boot-docker-compose.
#
# En producción (Railway) estas variables NO salen de este archivo: se configuran
# en el dashboard de Railway (o referenciando el plugin de Postgres/Redis que provisione ahí).

# --- Postgres ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asistec
DB_USER=asistec
DB_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth / JWT ---
# En prod es obligatorio (application-prod.yml no tiene default): generar con
# `openssl rand -base64 48` y cargarlo como secreto en Railway, nunca commitear el real.
JWT_SECRET=dev-only-secret-do-not-use-in-production-min-32-bytes
# Origen exacto del frontend (sin barra final) — CORS y la cookie de refresh dependen de esto.
FRONTEND_ORIGIN=http://localhost:4200
